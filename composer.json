{
    "name": "psc-acme/connector-catalog",
    "description": "Package connector-catalog for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ConnectorCatalog\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "vlucas/phpdotenv": "^5.0",
        "firebase/php-jwt": "^6.0",
        "psc-acme/tracker-product": "^1.0"
    },
    "require-dev": {
        "behat/behat": "^3.14",
        "rector/rector": "^1.0",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}